{
  "name": "frontend-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:cov": "ng test --code-coverage --watch=false --browsers=ChromeHeadless",
    "cypress:open": "npx cypress open",
    "cypress:run": "npx cypress run",
    "cypress:percy": "percy exec -- cypress run",
    "sonar": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$token=[Environment]::GetEnvironmentVariable('SONAR_TOKEN','User'); if([string]::IsNullOrWhiteSpace($token)){Write-Host 'SONAR_TOKEN no definido en User'; exit 1}; $env:SONAR_TOKEN=$token; npm run test:cov; if($LASTEXITCODE -ne 0){exit $LASTEXITCODE}; sonar-scanner\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.11",
    "@angular/common": "^20.2.0",
    "@angular/compiler": "^20.2.0",
    "@angular/core": "^20.2.0",
    "@angular/forms": "^20.2.0",
    "@angular/material": "^20.2.11",
    "@angular/platform-browser": "^20.2.0",
    "@angular/router": "^20.2.0",
    "@fontsource/material-icons": "^5.2.7",
    "@fontsource/roboto": "^5.2.10",
    "chromedriver": "^148.0.0",
    "dayjs": "^1.11.19",
    "jwt-decode": "^4.0.0",
    "rxjs": "~7.8.0",
    "selenium-webdriver": "^4.43.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.2.2",
    "@angular/cli": "^20.2.2",
    "@angular/compiler-cli": "^20.2.0",
    "@argos-ci/cypress": "^7.0.0",
    "@percy/cli": "^1.31.13",
    "@percy/cypress": "^3.1.8",
    "@types/jasmine": "~5.1.0",
    "axe-core": "^4.11.4",
    "cypress": "^15.14.2",
    "cypress-axe": "^1.7.0",
    "jasmine": "^6.2.0",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "mocha": "^11.7.5",
    "typescript": "~5.9.2"
  }
}
